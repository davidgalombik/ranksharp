# Database
DATABASE_URL=postgresql+asyncpg://trendtracker:trendtracker@localhost:5432/trendtracker
DATABASE_URL_SYNC=postgresql://trendtracker:trendtracker@localhost:5432/trendtracker

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Anthropic (Claude API for vision + NLP analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Etsy API (Tier 1 adapter)
ETSY_API_KEY=
ETSY_KEYSTRING=

# Apify — used by WayfairApifyAdapter (PerimeterX/Akamai blocks proxy-based scraping)
# Get token from apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxx

# Proxy pool for anti-bot scraping (e.g. Brightdata, Oxylabs, Smartproxy)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Storage for raw scraped data (local or S3)
RAW_DATA_PATH=/app/raw_data
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-2

# Scraping settings
SCRAPE_CONCURRENCY=5
REQUEST_DELAY_MIN=1.5
REQUEST_DELAY_MAX=4.0
MAX_RETRIES=3

# Analysis settings
VISION_MODEL=claude-opus-4-6
NLP_MODEL=claude-opus-4-6
TREND_CLUSTER_MIN_SIZE=5
